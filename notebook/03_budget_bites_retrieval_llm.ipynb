        "\n",
        "Return the answer in exactly this format:\n",
        "\n",
        "Recipe Name:\n",
        "Description:\n",
        "Ingredients:\n",
        "Steps:\n",
        "Total Time:\n",
        "Calories:\n",
        "Protein:\n",
        "Fats:\n",
        "Carbs:\n",
        "\"\"\".strip()\n",
        "\n",
